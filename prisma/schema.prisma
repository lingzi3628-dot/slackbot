// Prisma schema — Neon Postgres (serverless)
// Full database for SPYRO AI OS: users, conversations, projects, agents,
// knowledge, files, tasks, usage tracking, subscriptions, notifications.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Core: Users ───────────────────────────────────────────────────────
model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String
  password        String
  role            String   @default("user") // "user" | "guest" | "admin"
  avatarColor     String   @default("#8B5CF6")
  plan            String   @default("free") // "free" | "pro" | "plus" | "ultra" | "business" | "enterprise"
  workspaceType   String?  // selected workspace template ID
  studioType      String?  // selected studio type ID
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  resetToken      String?
  resetTokenExpiry DateTime?
  verified        Boolean  @default(false)

  // Relations
  conversations   Conversation[]
  projects        Project[]
  agents          Agent[]
  knowledgeDocs   KnowledgeDoc[]
  files           File[]
  tasks           Task[]
  notifications   Notification[]
  usageRecords    UsageRecord[]
  apiKeys         ApiKey[]
  subscriptions   Subscription[]
  activityLog     ActivityLog[]
  sessions        Session[]
}

// ── Sessions (DB-stored, revocable) ───────────────────────────────────
model Session {
  id          String   @id @default(cuid())
  userId      String
  token       String   @unique // the session token (random 32 bytes hex)
  ipAddress   String?
  userAgent   String?
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  revokedAt   DateTime? // null = active, set when user logs out
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ── Conversations & Messages ──────────────────────────────────────────
model Conversation {
  id          String   @id @default(cuid())
  userId      String
  projectId   String?
  title       String   @default("New chat")
  pinned      Boolean  @default(false)
  tags        String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  messages    Message[]

  @@index([userId])
  @@index([projectId])
}

model Message {
  id              String   @id @default(cuid())
  conversationId  String
  role            String   // "user" | "assistant" | "system"
  content         String
  type            String   @default("text") // "text" | "image" | "code" | "error"
  imageUrl        String?
  codeLanguage    String?
  tokenCount      Int      @default(0)
  createdAt       DateTime @default(now())
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

// ── Projects ──────────────────────────────────────────────────────────
model Project {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  status      String   @default("active") // "active" | "archived" | "completed"
  color       String   @default("#8B5CF6")
  pinned      Boolean  @default(false)
  progress    Int      @default(0) // 0-100
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  agents      Agent[]
  knowledge   KnowledgeDoc[]
  files       File[]
  tasks       Task[]

  @@index([userId])
}

// ── AI Agents ─────────────────────────────────────────────────────────
model Agent {
  id              String   @id @default(cuid())
  userId          String
  projectId       String?
  name            String
  description     String?
  instructions    String?
  avatar          String   @default("🤖")
  color           String   @default("#8B5CF6")
  status          String   @default("idle") // "idle" | "running" | "paused" | "error"
  model           String   @default("openai")
  temperature     Float    @default(0.7)
  responseStyle   String   @default("balanced")
  knowledgeSources String[] @default([])
  channels        String[] @default([]) // ["whatsapp", "telegram", ...]
  businessHours   Json?
  escalationRules Json?
  approvalMode    String   @default("auto")
  autoReplyMode   String   @default("always")
  apiKey          String?
  totalCalls      Int      @default(0)
  totalTokens     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project         Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
}

// ── Knowledge Base ────────────────────────────────────────────────────
model KnowledgeDoc {
  id          String   @id @default(cuid())
  userId      String
  projectId   String?
  title       String
  type        String   // "pdf" | "docx" | "md" | "csv" | "image" | "audio" | "video" | "url"
  content     String?
  url         String?
  collection  String?
  tags        String[] @default([])
  indexed     Boolean  @default(false)
  citations   Int      @default(0)
  sizeBytes   Int      @default(0)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
}

// ── Files ─────────────────────────────────────────────────────────────
model File {
  id          String   @id @default(cuid())
  userId      String
  projectId   String?
  name        String
  type        String   // "image" | "pdf" | "code" | "audio" | "video" | "document"
  mimeType    String?
  url         String?
  sizeBytes   Int      @default(0)
  aiSummary   String?
  favorite    Boolean  @default(false)
  tags        String[] @default([])
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
}

// ── Tasks ─────────────────────────────────────────────────────────────
model Task {
  id          String   @id @default(cuid())
  userId      String
  projectId   String?
  title       String
  description String?
  type        String   @default("manual") // "manual" | "ai"
  priority    String   @default("medium") // "low" | "medium" | "high"
  status      String   @default("pending") // "pending" | "done"
  dueDate     DateTime?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
}

// ── Usage Tracking (monthly resets) ───────────────────────────────────
model UsageRecord {
  id          String   @id @default(cuid())
  userId      String
  monthKey    String   // "2026-07"
  tokensUsed  Int      @default(0)
  imagesUsed  Int      @default(0)
  emailsUsed  Int      @default(0)
  apiCallsUsed Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, monthKey])
  @@index([userId])
}

// ── Subscriptions (Paystack) ──────────────────────────────────────────
model Subscription {
  id              String   @id @default(cuid())
  userId          String
  planId          String   // "free" | "pro" | "plus" | "ultra" | "business" | "enterprise"
  status          String   @default("active") // "active" | "cancelled" | "expired" | "past_due"
  paystackRef     String?  // Paystack transaction reference
  amountKES       Int      @default(0)
  startDate       DateTime @default(now())
  endDate         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── API Keys ──────────────────────────────────────────────────────────
model ApiKey {
  id          String   @id @default(cuid())
  userId      String
  name        String   // label for the key
  key         String   @unique // the actual API key
  callsUsed   Int      @default(0)
  callLimit   Int      @default(1000) // per month, based on plan
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Notifications ─────────────────────────────────────────────────────
model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String   // "ai" | "project" | "communication" | "workspace" | "security" | "system"
  title       String
  message     String
  read        Boolean  @default(false)
  archived    Boolean  @default(false)
  link        String?  // URL to navigate to
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Activity Log ──────────────────────────────────────────────────────
model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  type        String   // "agent" | "knowledge" | "comm" | "export" | "automation" | "chat" | "file" | "project"
  description String
  metadata    Json?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// ── Admin (separate auth from users) ─────────────────────────────────
model Admin {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  passwordHash  String
  role          String   @default("support") // "support" | "moderator" | "operations" | "security" | "developer" | "super"
  mfaSecret     String?
  mfaEnabled    Boolean  @default(false)
  active        Boolean  @default(true)
  lastLoginAt   DateTime?
  lastLoginIP   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  auditLogs     AuditLog[]
}

// ── Audit Log (admin actions, immutable) ──────────────────────────────
model AuditLog {
  id          String   @id @default(cuid())
  adminId     String
  action      String   // e.g. "user.ban", "feature.toggle", "announcement.send"
  target      String?  // what was acted upon (e.g. user ID)
  targetType  String?  // "user" | "feature" | "announcement" | "system"
  result      String   @default("success") // "success" | "failed"
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime @default(now())
  admin       Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([createdAt])
  @@index([action])
}

// ── Feature Flags ─────────────────────────────────────────────────────
model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "launch_studio", "developer_studio"
  name        String
  description String?
  enabled     Boolean  @default(true)
  rolloutPct  Int      @default(100) // percentage of users
  planRequired String? // minimum plan required (null = all plans)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Support Tickets ───────────────────────────────────────────────────
model SupportTicket {
  id          String   @id @default(cuid())
  userId      String
  subject     String
  message     String
  priority    String   @default("medium") // "low" | "medium" | "high" | "urgent"
  status      String   @default("open") // "open" | "pending" | "resolved" | "closed"
  assignedTo  String?  // admin ID
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ── Announcements ─────────────────────────────────────────────────────
model Announcement {
  id          String   @id @default(cuid())
  title       String
  message     String
  type        String   @default("info") // "info" | "maintenance" | "feature" | "security" | "welcome"
  targetPlan  String?  // null = all plans
  targetWorkspace String?
  scheduledFor DateTime?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Content Reports (moderation) ──────────────────────────────────────
model ContentReport {
  id          String   @id @default(cuid())
  reporterId  String?
  reportedUserId String?
  type        String   // "spam" | "abuse" | "prompt_injection" | "malicious_upload" | "rate_limit"
  content     String?
  status      String   @default("pending") // "pending" | "reviewing" | "resolved" | "dismissed"
  action      String?  // "warn" | "suspend" | "ban" | "delete" | "none"
  notes       String?
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?

  @@index([status])
}
