// Prisma schema — Neon Postgres (serverless)
// Set DATABASE_URL in .env or Vercel env vars to your Neon connection string.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String
  password        String
  role            String   @default("user") // "user" | "guest" | "admin"
  avatarColor     String   @default("#ff7a1a")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  resetToken      String?
  resetTokenExpiry DateTime?
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("New chat")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  Message[]

  @@index([userId])
}

model Message {
  id              String   @id @default(cuid())
  conversationId  String
  role            String   // "user" | "assistant"
  content         String
  type            String   @default("text") // "text" | "image"
  imageUrl        String?
  createdAt       DateTime @default(now())
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}
